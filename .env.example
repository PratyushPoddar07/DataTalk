# ===========================================
# QueryMind AI — Environment Variables
# ===========================================
# Copy this file as .env and fill in the values.
# For Vercel deployment, set these in the Vercel Dashboard:
#   Project Settings → Environment Variables
# ===========================================

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# AI Services (at least one is required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB (optional — for NoSQL database support)
MONGODB_URL=mongodb://localhost:27017

# Security
SECRET_KEY=generate-a-strong-random-secret-key

# CORS — add your Vercel production domain
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
